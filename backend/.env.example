# ===========================================
# PenguinX Backend Configuration
# BTC 15-Minute Claim System
# ===========================================
# Copy this file to .env and fill in values

# Polymarket API Base URLs
POLY_DATA_API_BASE=https://data-api.polymarket.com
POLY_GAMMA_API_BASE=https://gamma-api.polymarket.com
POLY_CLOB_BASE=https://clob.polymarket.com
POLY_RTDS_WS=wss://ws-live-data.polymarket.com
POLY_CLOB_WS=wss://ws-subscriptions-clob.polymarket.com/ws/

# Database (Supabase Postgres)
# Get your pooled connection string from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/database (Connection pooling tab)
SUPABASE_DATABASE_URL=postgresql://postgres.YOUR_REF:your_password@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres

# Simulation Configuration
SIMULATION_AMOUNT_USD=1
# Minimum price threshold for entering trades (0.78 = 78¢)
STRATEGY_ENTRY_THRESHOLD=0.78
# Maximum price threshold for entering trades (0.82 = 82¢)
STRATEGY_ENTRY_THRESHOLD_MAX=0.82
# Delay before claiming trades after market close (5 minutes)
CLAIM_DELAY_MS=300000

# Strategy Configuration
# Maximum number of simultaneous open positions
MAX_SIMULTANEOUS_POSITIONS=50
# Seconds before market end to start evaluating opportunities (150 = 2.5 minutes)
NEAR_END_WINDOW_SECONDS=420
# Milliseconds between market scans (2 minutes)
SCAN_INTERVAL_MS=120000
# Minimum look-ahead time for market discovery (2 hours)
MIN_LOOK_AHEAD_MS=7200000

# Stop-Loss Configuration
# Enable/disable stop-loss protection (defaults to true)
STOP_LOSS_ENABLED=true
# Price threshold that triggers stop-loss (0.50 = 50¢)
STOP_LOSS_THRESHOLD=0.50

# API Server
PORT=4000
HOST=0.0.0.0

# Logging
LOG_LEVEL=info

# Environment
NODE_ENV=development

# Admin Operations
WIPE_PASSWORD=your_secure_password_here
