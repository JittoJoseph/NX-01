
# ── Database ──────────────────────────────────────────────────
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Polymarket ────────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=

# ── Strategy ──────────────────────────────────────────────────
MARKET_WINDOW=5M
TRADE_FROM_WINDOW_SECONDS=90
ENTRY_PRICE_THRESHOLD=0.94
MAX_ENTRY_PRICE=0.98
STOP_LOSS_PRICE_TRIGGER=0.75

# ── Portfolio ─────────────────────────────────────────────────
STARTING_CAPITAL=10

# ── Server ────────────────────────────────────────────────────
PORT=4000
ADMIN_PASSWORD=change_me
