# ===========================================
# PenguinX Backend Configuration
# BTC End-of-Window Micro-Profit System
# ===========================================
# Copy this file to .env and fill in values

# ── Database ────────────────────────────────
# Supabase pooled connection string
# Dashboard → Project → Settings → Database → Connection pooling
SUPABASE_DATABASE_URL=postgresql://postgres.YOUR_REF:your_password@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres

# ── Strategy ────────────────────────────────
# Market window to trade: 5M | 15M | 1H | 4H | 1D
MARKET_WINDOW=5M

# Seconds before window end to start evaluating entries (default: 30)
TRADE_FROM_WINDOW_SECONDS=30

# Minimum price (0–1) to enter a limit buy (default: 0.95 = 95¢)
ENTRY_PRICE_THRESHOLD=0.95

# Maximum price (0–1) for limit buy orders (default: 0.95 = 95¢)
MAX_ENTRY_PRICE=0.98

# Max simultaneous open positions (default: 5)
MAX_SIMULTANEOUS_POSITIONS=5

# Minutes after market close to watch for resolution (default: 5)
RESOLUTION_WATCH_MINUTES=5

# Minimum BTC price distance from target in USD for confidence (default: 50)
MIN_BTC_DISTANCE_USD=10

# Milliseconds between market discovery scans (default: 60000 = 1 min)
SCAN_INTERVAL_MS=60000

# ── Simulation ──────────────────────────────
# USD amount per simulated trade (default: 1)
SIMULATION_AMOUNT_USD=1

# ── Stop-Loss ───────────────────────────────
# Enable stop-loss functionality (default: true)
STOP_LOSS_ENABLED=true

# Price at which to stop-loss an open position (default: 0.85 = 85¢)
STOP_LOSS_THRESHOLD=0.85

# ── API Server ──────────────────────────────
PORT=4000
HOST=0.0.0.0

# ── Logging ─────────────────────────────────
# trace | debug | info | warn | error
LOG_LEVEL=info

# ── Environment ─────────────────────────────
NODE_ENV=development

# ── Admin ───────────────────────────────────
# Password required to call POST /api/admin/wipe
WIPE_PASSWORD=your_secure_password_here
